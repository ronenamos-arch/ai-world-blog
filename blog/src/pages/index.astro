---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class="relative -mx-4 mb-10 overflow-hidden rounded-b-3xl border-b border-white/5 premium-shadow"
      style="min-height: 400px;"
    >
      <!-- תמונת רקע -->
      <img
        src="/hero-bg.jpg"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
      />
      <!-- gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent"></div>

      <!-- תוכן -->
      <div class="relative h-full flex flex-col justify-end px-6 pt-12 pb-12">
        <div class="glassmorphism max-w-2xl p-8 rounded-3xl premium-shadow">
          <div class="flex items-center gap-4">
            <h1 class="text-4xl font-extrabold sm:text-6xl text-accent tracking-tight">
              עולם ה AI
            </h1>
            <a
              target="_blank"
              href="/rss.xml"
              aria-label="rss feed"
              title="RSS Feed"
              class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10 hover:bg-accent/20 transition-colors"
            >
              <IconRss
                width={20}
                height={20}
                class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
              />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>

          <p class="mt-6 text-foreground/90 text-lg sm:text-xl leading-relaxed font-medium">
            בלוג בעברית על כלי AI חדשים, מדריכים נגישים והסברים ישירים — למי שרוצה להבין
            איך להשתמש באמת ב-AI, בלי בלה-בלה שיווקי.
          </p>

          {
            SOCIALS.length > 0 && (
              <div class="mt-8 flex items-center gap-4">
                <span class="text-sm font-bold uppercase tracking-wider text-accent/70">צרו קשר:</span>
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">מומלצים</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">פוסטים אחרונים</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        כל הפוסטים
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
