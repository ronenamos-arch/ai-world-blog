---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ogImage, ...props } = data;

const postUrl = getPath(id, filePath);
const imageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src ?? null;
---

<li class="my-8">
  <a
    href={postUrl}
    class="group block overflow-hidden rounded-2xl border border-border transition-all duration-300 premium-shadow premium-shadow-hover"
  >
    <!-- תמונה -->
    <div class="aspect-video w-full overflow-hidden bg-muted">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-accent/20 to-accent/5">
          <span class="text-4xl opacity-30">🤖</span>
        </div>
      )}
    </div>

    <!-- תוכן -->
    <div class="p-5">
      <Heading
        class="text-lg font-semibold text-accent group-hover:underline decoration-dashed underline-offset-4"
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
      <Datetime class="mt-1" {...props} />
      <p class="mt-2 text-sm text-foreground/75 line-clamp-2">{description}</p>
      
      <div class="mt-4 flex items-center text-accent font-bold text-sm group-hover:gap-2 transition-all">
        <span>קרא עוד</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="rtl:rotate-180 ml-1">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </div>
    </div>
  </a>
</li>
