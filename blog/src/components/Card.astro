---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ogImage, ...props } = data;

const postUrl = getPath(id, filePath);
const imageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src ?? null;
---

<li class="my-4">
  <a
    href={postUrl}
    class="group block h-full overflow-hidden rounded-3xl border border-border bg-background/50 transition-all duration-300 hover:-translate-y-1 hover:border-accent/50 hover:shadow-xl hover:shadow-accent/5"
  >
    <!-- תמונה -->
    <div class="aspect-video w-full overflow-hidden bg-muted">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-accent/20 to-accent/5">
          <span class="text-4xl opacity-30">🤖</span>
        </div>
      )}
    </div>

    <!-- תוכן -->
    <div class="flex flex-col p-6">
      <div class="mb-2 flex items-center gap-2">
        {data.tags.slice(0, 1).map(tag => (
          <span class="text-[10px] font-bold uppercase tracking-widest text-accent/80">{tag}</span>
        ))}
      </div>
      
      <Heading
        class="text-xl font-bold leading-tight text-foreground group-hover:text-accent transition-colors"
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
      
      <Datetime class="mt-2 text-xs opacity-70" {...props} />
      
      <p class="mt-3 text-sm leading-relaxed text-foreground/70 line-clamp-2">
        {description}
      </p>
      
      <div class="mt-6 flex items-center text-accent font-bold text-sm">
        <span class="border-b-2 border-transparent group-hover:border-accent transition-all">קרא עוד</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="rtl:rotate-180 ms-2 transition-transform group-hover:translate-x-1">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </div>
    </div>
  </a>
</li>
