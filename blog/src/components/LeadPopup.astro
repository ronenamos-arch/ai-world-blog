---
interface Props {
  postTitle: string;
  guideTitle?: string;
}

const { postTitle, guideTitle = "המדריך המלא" } = Astro.props;
---

<div 
  id="lead-popup" 
  class="fixed bottom-6 right-6 z-[100] w-[350px] translate-y-[150%] opacity-0 transition-all duration-700 ease-out sm:right-10"
>
  <div class="relative overflow-hidden rounded-3xl border border-border bg-background/80 p-6 shadow-2xl backdrop-blur-2xl dark:bg-background/90">
    <button 
      id="close-popup" 
      class="absolute left-4 top-4 text-2xl opacity-40 hover:opacity-100 transition-opacity"
      aria-label="סגור"
    >
      ×
    </button>

    <div class="flex items-center gap-4">
      <div class="flex size-12 items-center justify-center rounded-2xl bg-accent text-3xl shadow-lg shadow-accent/20">
        📘
      </div>
      <div>
        <h3 class="text-lg font-black leading-tight text-accent">קבלו את {guideTitle}</h3>
        <p class="text-sm opacity-70">בחינם ישירות למייל</p>
      </div>
    </div>

    <form id="popup-form" class="mt-6 flex flex-col gap-3">
      <input type="hidden" name="postTitle" value={postTitle} />
      <input 
        type="email" 
        name="email" 
        required 
        placeholder="המייל שלך..." 
        class="rounded-xl border border-border bg-background/50 p-3 text-sm outline-none transition-all focus:border-accent"
      />
      <button 
        type="submit" 
        id="popup-submit"
        class="rounded-xl bg-accent p-3 text-sm font-bold text-background shadow-md transition-all hover:brightness-110 active:scale-95 disabled:opacity-50"
      >
        שלחו לי עכשיו
      </button>
      <p id="popup-status" class="text-center text-[10px] font-bold opacity-0 transition-all"></p>
    </form>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const popup = document.querySelector("#lead-popup") as HTMLElement;
    const closeBtn = document.querySelector("#close-popup");
    const form = document.querySelector("#popup-form") as HTMLFormElement;
    const status = document.querySelector("#popup-status") as HTMLElement;
    const submitBtn = document.querySelector("#popup-submit") as HTMLButtonElement;

    if (!popup || !closeBtn || !form) return;

    // הצגת הפופאפ לאחר גלילה של 30% או לאחר 5 שניות
    let shown = false;
    const showPopup = () => {
      if (shown) return;
      shown = true;
      popup.classList.remove("translate-y-[150%]", "opacity-0");
    };

    const handleScroll = () => {
      const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      if (scrollPercent > 30) {
        showPopup();
        window.removeEventListener("scroll", handleScroll);
      }
    };

    window.addEventListener("scroll", handleScroll);
    setTimeout(showPopup, 8000); // גיבוי לאחר 8 שניות

    // סגירה
    closeBtn.addEventListener("click", () => {
      popup.classList.add("translate-y-[150%]", "opacity-0");
      // מניעת הצגה חוזרת בסשן הנוכחי
      sessionStorage.setItem("lead-popup-closed", "true");
    });

    if (sessionStorage.getItem("lead-popup-closed")) {
      shown = true; // אל תראה שוב
    }

    // שליחה
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.innerHTML = "שולח...";

      const formData = new FormData(form);
      const data = {
        email: formData.get("email"),
        postTitle: formData.get("postTitle"),
      };

      const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzsY4v0hDIaGEouQcnErXjNfOiZ7UcFyb3Jd4LryW621-I3ldZgY65Bqf47_u5Zah8P/exec"; 

      try {
        if (SCRIPT_URL !== "YOUR_SCRIPT_URL_HERE") {
          await fetch(SCRIPT_URL, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });
        }
        
        status.textContent = "✅ נשלח! המדריך בדרך.";
        status.classList.add("text-green-500", "opacity-100");
        setTimeout(() => {
          popup.classList.add("translate-y-[150%]", "opacity-0");
        }, 2000);
      } catch (error) {
        status.textContent = "❌ שגיאה. נסו שוב.";
        status.classList.add("text-red-500", "opacity-100");
        submitBtn.disabled = false;
      }
    });
  });
</script>
